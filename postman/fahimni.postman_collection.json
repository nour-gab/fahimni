{
  "info": {
    "name": "Fahimni API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" },
    { "key": "courseId", "value": "" },
    { "key": "studentId", "value": "" },
    { "key": "recipientId", "value": "" },
    { "key": "assignmentId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Auth Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"prof@example.com\",\n  \"password\": \"Secret123!\",\n  \"full_name\": \"Prof Ada\",\n  \"role\": \"PROFESSOR\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] }
      }
    },
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"prof@example.com\",\n  \"password\": \"Secret123!\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
      }
    },
    {
      "name": "Create Course",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Intro to AI\",\n  \"code\": \"AI-101\",\n  \"description\": \"Foundations of modern AI systems\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/courses", "host": ["{{baseUrl}}"], "path": ["api", "v1", "courses"] }
      }
    },
    {
      "name": "Create Announcement",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_id\": \"{{courseId}}\",\n  \"title\": \"Exam Reminder\",\n  \"body\": \"Midterm opens Friday 9am.\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/announcements", "host": ["{{baseUrl}}"], "path": ["api", "v1", "announcements"] }
      }
    },
    {
      "name": "Send Direct Message",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"recipient_id\": \"{{recipientId}}\",\n  \"content\": \"Please review assignment 2 feedback.\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/messages", "host": ["{{baseUrl}}"], "path": ["api", "v1", "messages"] }
      }
    },
    {
      "name": "Create Assignment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_id\": \"{{courseId}}\",\n  \"title\": \"Assignment 1\",\n  \"description\": \"Build a FastAPI endpoint\",\n  \"total_points\": 100\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/grades/assignments", "host": ["{{baseUrl}}"], "path": ["api", "v1", "grades", "assignments"] }
      }
    },
    {
      "name": "Post Grade",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assignment_id\": \"{{assignmentId}}\",\n  \"student_id\": \"{{studentId}}\",\n  \"score\": 91,\n  \"feedback\": \"Strong work\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/grades", "host": ["{{baseUrl}}"], "path": ["api", "v1", "grades"] }
      }
    },
    {
      "name": "AI RAG Ask",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_id\": \"{{courseId}}\",\n  \"question\": \"Explain recursion simply\",\n  \"task_hint\": \"simple explanation\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/ai/rag/ask", "host": ["{{baseUrl}}"], "path": ["api", "v1", "ai", "rag", "ask"] }
      }
    },
    {
      "name": "AI Hybrid Search",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_id\": \"{{courseId}}\",\n  \"query\": \"Find where recursion is explained\",\n  \"k\": 5\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/ai/search/hybrid", "host": ["{{baseUrl}}"], "path": ["api", "v1", "ai", "search", "hybrid"] }
      }
    },
    {
      "name": "AI Teacher Analyze",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_id\": \"{{courseId}}\",\n  \"content\": \"Recursion is when a function calls itself. Base cases stop infinite loops.\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/ai/teacher/analyze", "host": ["{{baseUrl}}"], "path": ["api", "v1", "ai", "teacher", "analyze"] }
      }
    },
    {
      "name": "AI Multi-Agent Orchestrate",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_id\": \"{{courseId}}\",\n  \"student_id\": \"{{studentId}}\",\n  \"prompt\": \"Build me a study strategy for recursion\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/ai/agents/orchestrate", "host": ["{{baseUrl}}"], "path": ["api", "v1", "ai", "agents", "orchestrate"] }
      }
    },
    {
      "name": "AI Answer Evaluate",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reference_answer\": \"Recursion solves a problem by reducing it to smaller versions and using a base case.\",\n  \"student_answer\": \"A recursive function calls itself with smaller input until a stop case.\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/ai/answers/evaluate", "host": ["{{baseUrl}}"], "path": ["api", "v1", "ai", "answers", "evaluate"] }
      }
    }
  ]
}
